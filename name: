name: CI

on:
  push:
    branches: [master]
  pull_request:
    branches: [master]

jobs:
  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3
      - uses: actions/setup-python@v4
        with:
          python-version: '3.12'

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install -r requirements.txt
          pip install -r dev-requirements.txt

      - name: Lint with ruff
        continue-on-error: true
        run: ruff check orchestration/ agents/ core/ meta_rl/ trading/ web/

      - name: Type check with mypy
        continue-on-error: true
        run: mypy orchestration/ agents/ core/ meta_rl/ trading/ web/

      - name: Security lint with bandit
        continue-on-error: true
        run: bandit -r orchestration/ agents/ core/ meta_rl/ trading/ -ll

      - name: Audit dependencies for vulnerabilities
        continue-on-error: true
        run: pip-audit

      - name: Run unit tests with coverage
        run: |
          python -m pytest tests/ -v --cov=. --cov-report=xml --cov-fail-under=60

      - name: Compare backtest modes
        run: python scripts/compare_backtest_modes.py --ci
