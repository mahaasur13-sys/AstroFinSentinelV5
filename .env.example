# === CCXT Binance Configuration ===
# Получи ключи здесь: https://www.binance.com/en/my/settings/api
CCXT_API_KEY=your_binance_api_key_here
CCXT_API_SECRET=your_binance_api_secret_here

# Режим работы (оставь true для тестов!)
CCXT_SANDBOX_MODE=true

# Включи настоящий live режим (только после тестирования!)
CCXT_LIVE_MODE=false

# Дополнительно
META_RL_LIVE_ENABLED=false
