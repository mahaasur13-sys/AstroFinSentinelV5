{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GitAgent Manifest Schema v1.1 - Test Compatible",
  "type": "object",
  "required": ["name", "description", "version", "model", "capabilities", "tools", "rules"],
  "additionalProperties": true,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$",
      "minLength": 3,
      "maxLength": 60
    },
    "description": {
      "type": "string",
      "minLength": 5,
      "maxLength": 300
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+(\\.\\d+)?$"
    },
    "model": {
      "type": "object",
      "required": ["provider", "name"],
      "properties": {
        "provider": { "type": "string", "enum": ["openai", "anthropic", "groq", "vercel", "minimax", "custom"] },
        "name": { "type": "string", "minLength": 3 },
        "temperature": { "type": "number", "minimum": 0.0, "maximum": 2.0 }
      },
      "additionalProperties": false
    },
    "capabilities": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true,
      "minItems": 1
    },
    "tools": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "rules": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "output_schema": {
      "type": "object",
      "properties": {
        "signal": { "type": "string" },
        "confidence": { "type": "string" },
        "reasoning": { "type": "string" },
        "sources": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "sub_agents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "weight": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
        }
      }
    },
    "weight": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "domain": {
      "type": "string",
      "enum": ["astro", "fundamental", "quant", "macro", "technical", "options", "sentiment", "risk", "electional"]
    },
    "compliance": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
